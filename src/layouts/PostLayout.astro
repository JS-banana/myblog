---
import BaseLayout from './BaseLayout.astro';
import { tagToSlug } from '@/utils/tags';
import { getAdjacentPosts, postHref } from '@/utils/adjacent';
import CodeCopyScript from '@/components/CodeCopyScript.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  readingMinutes?: number;
  postId?: string;
  slug?: string;
}

const { title, description, date, updated, tags = [], readingMinutes, postId, slug } = Astro.props;
const { prev, next } = postId ? await getAdjacentPosts(postId) : { prev: null, next: null };

function formatDate(d: Date): string {
  return d.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'Asia/Shanghai',
  });
}
---
<BaseLayout title={title} description={description} type="article" date={date} updated={updated}>
  <ReadingProgress />
  <article>
    <header class="post-header">
      <h1 transition:name={slug ? `title-${slug}` : undefined}>{title}</h1>
      <p class="post-meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {readingMinutes && <span>· {readingMinutes} 分钟</span>}
        {updated && <span class="post-updated">· 更新于 {formatDate(updated)}</span>}
      </p>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <a href={`/tags/${tagToSlug(tag)}`} class="pill">{tag}</a>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
    {(prev || next) && (
      <nav class="post-nav" aria-label="上下篇导航">
        {prev
          ? <a href={postHref(prev)} class="post-nav-prev">← {prev.data.title}</a>
          : <span />}
        {next
          ? <a href={postHref(next)} class="post-nav-next">{next.data.title} →</a>
          : <span />}
      </nav>
    )}
  </article>
  <CodeCopyScript />
</BaseLayout>
