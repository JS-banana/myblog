---
import type { CollectionEntry } from 'astro:content';
import { fromDescriptionOrBody } from '@/utils/excerpt';
import { getCanonicalYear } from '@/utils/postYear';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    timeZone: 'Asia/Shanghai',
  });
}
---
<ul class="post-list">
  {posts.map((post) => {
    const year = getCanonicalYear(post);
    const href = `/posts/${year}/${post.data.slug}`;
    const excerpt = fromDescriptionOrBody({
      description: post.data.description,
      body: post.body,
      maxLength: 120,
    });
    return (
      <li class="post-item">
        <a href={href} class="post-link">
          <h3 class="post-title" transition:name={`title-${post.data.slug}`}>{post.data.title}</h3>
          <time class="post-date" datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          {excerpt && <p class="post-excerpt">{excerpt}</p>}
        </a>
      </li>
    );
  })}
</ul>
