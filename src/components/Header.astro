---
import { SITE } from '@/config/site';
import ThemeToggle from './ThemeToggle.astro';
import SearchDialog from './SearchDialog.astro';

const pathname = Astro.url.pathname;
const isActive = (prefix: string) =>
  prefix === '/' ? pathname === '/' || pathname.startsWith('/page/') : pathname.startsWith(prefix);

const links = [
  { href: '/', label: '文章' },
  { href: '/archives', label: '归档' },
  { href: '/tags', label: '标签' },
  { href: '/about', label: '关于' },
];
---
<header class="site-header">
  <nav class="site-nav">
    <a href="/" class="site-title">{SITE.name}</a>
    <ul class="nav-links">
      {links.map(({ href, label }) => (
        <li>
          <a href={href} class={isActive(href) ? 'active' : ''}>
            <span class={isActive(href) ? 'marker' : 'marker-empty'} aria-hidden="true">
              {isActive(href) ? '◇' : ''}
            </span>{label}
          </a>
        </li>
      ))}
    </ul>
    <SearchDialog />
    <ThemeToggle />
  </nav>
</header>
