---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/PostList.astro';
import { getAllTags, tagToSlug } from '@/utils/tags';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map(({ tag, posts }) => ({
    params: { tag: tagToSlug(tag) },
    props: { tag, posts },
  }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag} · 相关文章`}>
  <p class="muted" style="margin-bottom:var(--space-md);"><a href="/tags">← 所有标签</a></p>
  <h1 style="font-size:1.5rem;font-weight:700;margin-bottom:0.5rem;letter-spacing:-0.02em;">#{tag}</h1>
  <p class="muted" style="margin-bottom:var(--space-lg);">共 {posts.length} 篇</p>
  <PostList posts={posts} />
</BaseLayout>
